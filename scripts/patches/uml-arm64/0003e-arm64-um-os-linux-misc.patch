From: DevBox UML arm64 Port
Subject: [PATCH 3e/7] arm64/um: add os-Linux signal, prctl, uaccess
diff --git a/arch/arm64/um/os-Linux/signal.c b/arch/arm64/um/os-Linux/signal.c
new file mode 100644
--- /dev/null
+++ b/arch/arm64/um/os-Linux/signal.c
@@ -0,0 +1,38 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * arch/arm64/um/os-Linux/signal.c
+ * Host-side signal setup for UML on arm64.
+ */
+
+#include <signal.h>
+#include <string.h>
+#include <errno.h>
+#include "os.h"
+#include "skas/skas.h"
+
+void set_sigstack(void *sig_stack, int size)
+{
+	stack_t ss = {
+		.ss_sp    = sig_stack,
+		.ss_flags = 0,
+		.ss_size  = size,
+	};
+
+	if (sigaltstack(&ss, NULL) < 0)
+		panic("sigaltstack failed: %s", strerror(errno));
+}
+
+void remove_sigstack(void)
+{
+	stack_t ss = { .ss_flags = SS_DISABLE };
+	sigaltstack(&ss, NULL);
+}
+
+void (*arch_get_signal_handler(int sig))(int, struct siginfo *, void *)
+{
+	return NULL;
+}
+
+void arch_do_signal(struct pt_regs *regs, int sig)
+{
+}
diff --git a/arch/arm64/um/os-Linux/prctl.c b/arch/arm64/um/os-Linux/prctl.c
new file mode 100644
--- /dev/null
+++ b/arch/arm64/um/os-Linux/prctl.c
@@ -0,0 +1,16 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * arch/arm64/um/os-Linux/prctl.c
+ * Disable PAC so ptrace register reads/writes are not corrupted.
+ */
+
+#include <sys/prctl.h>
+#include "os.h"
+
+void arch_prctl_defaults(void)
+{
+	prctl(PR_PAC_RESET_KEYS,
+	      PR_PAC_APIAKEY | PR_PAC_APIBKEY |
+	      PR_PAC_APDAKEY | PR_PAC_APDBKEY | PR_PAC_APGAKEY,
+	      0, 0, 0);
+}
diff --git a/arch/arm64/um/os-Linux/uaccess.c b/arch/arm64/um/os-Linux/uaccess.c
new file mode 100644
--- /dev/null
+++ b/arch/arm64/um/os-Linux/uaccess.c
@@ -0,0 +1,11 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
