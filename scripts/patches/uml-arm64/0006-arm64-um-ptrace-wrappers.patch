From: DevBox UML arm64 Port
Subject: [PATCH 6/13] arm64/um: add os-Linux/registers.c with full GP + FP/SIMD + ptrace wrappers

diff --git a/arch/arm64/um/os-Linux/registers.c b/arch/arm64/um/os-Linux/registers.c
new file mode 100644
--- /dev/null
+++ b/arch/arm64/um/os-Linux/registers.c
@@ -0,0 +1,117 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * arch/arm64/um/os-Linux/registers.c вЂ” host-side register access for UML arm64.
+ */
+
+#include <sys/ptrace.h>
+#include <sys/uio.h>
+#include <sys/user.h>
+#include <elf.h>
+#include <errno.h>
+#include <string.h>
+#include <stdlib.h>
+#include "os.h"
+#include "registers.h"
+#include "skas/skas.h"
+#include <longjmp.h>
+#include <sysdep/archsetjmp.h>
+#include <sysdep/ptrace_user.h>
+
+/* в”Ђв”Ђ GP register access (struct user_pt_regs via NT_PRSTATUS) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
+
+int save_registers(int pid, struct uml_pt_regs *regs)
+{
+	struct iovec iov = {
+		.iov_base = regs->gp,
+		.iov_len  = sizeof(regs->gp),
+	};
+	if (ptrace(PTRACE_GETREGSET, pid, (void *)(long)NT_PRSTATUS, &iov) < 0)
+		return -errno;
+	return 0;
+}
+
+int restore_registers(int pid, struct uml_pt_regs *regs)
+{
+	struct iovec iov = {
+		.iov_base = regs->gp,
+		.iov_len  = sizeof(regs->gp),
+	};
+	if (ptrace(PTRACE_SETREGSET, pid, (void *)(long)NT_PRSTATUS, &iov) < 0)
+		return -errno;
+	return 0;
+}
+
+/*
+ * ptrace_getregs / ptrace_setregs вЂ” called by arch/um/os-Linux/registers.c
+ * init_pid_registers(). On arm64 we route through GETREGSET.
+ */
+int ptrace_getregs(long pid, unsigned long *regs_out)
+{
+	struct iovec iov = {
+		.iov_base = regs_out,
+		.iov_len  = 34 * sizeof(unsigned long long),
+	};
+	if (ptrace(PTRACE_GETREGSET, pid, (void *)(long)NT_PRSTATUS, &iov) < 0)
+		return -errno;
+	return 0;
+}
+
+int ptrace_setregs(long pid, unsigned long *regs_in)
+{
+	struct iovec iov = {
+		.iov_base = regs_in,
+		.iov_len  = 34 * sizeof(unsigned long long),
+	};
+	if (ptrace(PTRACE_SETREGSET, pid, (void *)(long)NT_PRSTATUS, &iov) < 0)
+		return -errno;
+	return 0;
+}
+
+/* в”Ђв”Ђ FP/SIMD register access (struct user_fpsimd_state via NT_PRFPREG) в”Ђв”Ђв”Ђв”Ђ */
+
+int get_fp_registers(int pid, unsigned long *regs)
+{
+	struct iovec iov = {
+		.iov_base = regs,
+		.iov_len  = FP_SIZE * sizeof(unsigned long),
+	};
+	if (ptrace(PTRACE_GETREGSET, pid, (void *)(long)NT_PRFPREG, &iov) < 0)
+		return -errno;
+	return 0;
+}
+
+int put_fp_registers(int pid, unsigned long *regs)
+{
+	struct iovec iov = {
+		.iov_base = regs,
+		.iov_len  = FP_SIZE * sizeof(unsigned long),
+	};
+	if (ptrace(PTRACE_SETREGSET, pid, (void *)(long)NT_PRFPREG, &iov) < 0)
+		return -errno;
+	return 0;
+}
+
+/* в”Ђв”Ђ arch_init_registers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
+
+void arch_init_registers(int pid)
+{
+	/*
+	 * Nothing to probe вЂ” FP/SIMD is mandatory on ARMv8.
+	 * SVE probing can be added here in future.
+	 */
+}
+
+/* в”Ђв”Ђ get_thread_reg вЂ” jmp_buf accessor for UML context switch в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
+
+unsigned long get_thread_reg(int reg, jmp_buf *buf)
+{
+	switch (reg) {
+	case HOST_PC:
+		return (*buf)[JB_IP];
+	case HOST_SP:
+		return (*buf)[JB_SP];
+	default:
+		printk(UM_KERN_ERR "get_thread_reg: unknown reg %d\n", reg);
+		return 0;
+	}
+}
