From: DevBox UML arm64 Port
Subject: [PATCH 3b/7] arm64/um: add stub_segv.c

diff --git a/arch/arm64/um/stub_segv.c b/arch/arm64/um/stub_segv.c
new file mode 100644
--- /dev/null
+++ b/arch/arm64/um/stub_segv.c
@@ -0,0 +1,26 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * arch/arm64/um/stub_segv.c
+ *
+ * Stub mapped into every UML process at a fixed address.
+ * When a guest process faults, SIGSEGV lands here.
+ * Issues SVC #0 so the UML kernel thread wakes and handles the fault.
+ */
+
+#include <linux/unistd.h>
+#include "stub-data.h"
+
+void __attribute__ ((section (".stub"))) stub_segv(void)
+{
+	__asm__ __volatile__(
+		"mov x8, %0\n"
+		"svc #0\n"
+		:
+		: "i"(__NR_getpid)
+		: "x8", "x0"
+	);
+}
+
+void __attribute__ ((section (".stub"))) stub_end(void)
+{
+}
