From: DevBox UML arm64 Port
Subject: [PATCH 3/4] arm64/um: add signal handling and os-Linux layer

UML intercepts SIGSEGV/SIGTRAP from guest processes to implement the
skas (Separate Kernel Address Space) execution model. On arm64 we use
PTRACE_GETREGSET/SETREGSET with NT_PRSTATUS iovec to read/write the
full user_pt_regs structure atomically.

Key differences from x86:
- NT_PRSTATUS iovec used instead of PTRACE_GETREGS (arm64 has no
  PTRACE_GETREGS, only the regset API)
- Syscall NR is in x8 (not orig_eax/orig_rax)
- PTRACE_SYSCALL works the same way for skas mode

diff --git a/arch/arm64/um/signal.c b/arch/arm64/um/signal.c
new file mode 100644
--- /dev/null
+++ b/arch/arm64/um/signal.c
@@ -0,0 +1,82 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * arch/arm64/um/signal.c — UML signal frame setup for arm64 guests.
+ *
+ * When UML delivers a signal to a guest process it builds a signal frame
+ * on the guest stack, exactly as a native arm64 kernel would.  The guest
+ * sigreturn trampoline (installed in the vDSO page by UML) calls
+ * __NR_rt_sigreturn to tear the frame down.
+ */
+
+#include <linux/signal.h>
+#include <linux/uaccess.h>
+#include <asm/ucontext.h>
+#include <asm/unistd.h>
+#include "sysdep/ptrace.h"
+
+/* arm64 rt_sigframe mirrors the native layout so glibc unwinders work */
+struct rt_sigframe {
+	struct siginfo info;
+	struct ucontext uc;
+};
+
+int setup_signal_stack_si(unsigned long stack_top, int sig,
+			  struct k_sigaction *ka, struct pt_regs *regs,
+			  siginfo_t *info, sigset_t *mask)
+{
+	struct rt_sigframe __user *frame;
+	unsigned long sp;
+	int err = 0;
+
+	sp = (stack_top - sizeof(*frame)) & ~15UL;
+	frame = (struct rt_sigframe __user *)sp;
+
+	err |= copy_siginfo_to_user(&frame->info, info);
+
+	/* uc_mcontext holds the saved register state */
+	err |= __put_user(0, &frame->uc.uc_flags);
+	err |= __put_user(NULL, &frame->uc.uc_link);
+	err |= __save_altstack(&frame->uc.uc_stack, regs->regs.sp);
+	err |= copy_to_user(&frame->uc.uc_mcontext.regs, &regs->regs,
+			    sizeof(regs->regs));
+	err |= __copy_to_user(&frame->uc.uc_sigmask, mask, sizeof(*mask));
+
+	if (err)
+		return err;
+
+	/* Set up guest regs to enter the signal handler */
+	regs->regs.pc  = (unsigned long)ka->sa.sa_handler;
+	regs->regs.sp  = sp;
+	regs->regs.regs[0] = sig;           /* x0 = signum */
+	regs->regs.regs[1] = (unsigned long)&frame->info; /* x1 = siginfo */
+	regs->regs.regs[2] = (unsigned long)&frame->uc;   /* x2 = ucontext */
+
+	/*
+	 * x30 = restorer trampoline address (in UML vDSO).
+	 * The trampoline executes: mov x8, __NR_rt_sigreturn; svc #0
+	 */
+	regs->regs.regs[30] = (unsigned long)ka->sa.sa_restorer;
+
+	return 0;
+}
+
+long sys_rt_sigreturn(void)
+{
+	struct pt_regs *regs = current_pt_regs();
+	struct rt_sigframe __user *frame;
+	sigset_t set;
+
+	frame = (struct rt_sigframe __user *)regs->regs.sp;
+
+	if (__copy_from_user(&set, &frame->uc.uc_sigmask, sizeof(set)))
+		goto badframe;
+
+	set_current_blocked(&set);
+
+	if (copy_from_user(&regs->regs, &frame->uc.uc_mcontext.regs,
+			   sizeof(regs->regs)))
+		goto badframe;
+
+	return regs->regs.regs[0]; /* return x0 from restored context */
+
+badframe:
+	force_sig(SIGSEGV);
+	return 0;
+}

diff --git a/arch/arm64/um/stub_segv.c b/arch/arm64/um/stub_segv.c
new file mode 100644
--- /dev/null
+++ b/arch/arm64/um/stub_segv.c
@@ -0,0 +1,38 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * arch/arm64/um/stub_segv.c
+ *
+ * This stub is mapped into every UML process at a fixed address.
+ * When a guest process faults, the host kernel delivers SIGSEGV here.
+ * The stub saves minimal state then executes a syscall so the UML
+ * kernel thread wakes up and can inspect/modify the guest.
+ *
+ * On arm64 we use a simple SVC #0 after setting x8 = __NR_getpid.
+ * The UML ptrace layer intercepts this syscall entry and handles the
+ * fault before the syscall actually runs.
+ */
+
+#include <linux/unistd.h>
+#include "stub-data.h"
+
+void __attribute__ ((section (".stub"))) stub_segv(void)
+{
+	/*
+	 * arm64 inline-asm: issue a syscall (SVC #0).
+	 * x8 = syscall number, result in x0.
+	 * The UML kernel intercepts this at PTRACE_EVENT_SECCOMP or
+	 * plain syscall-entry ptrace stop.
+	 */
+	__asm__ __volatile__(
+		"mov x8, %0\n"
+		"svc #0\n"
+		:
+		: "i"(__NR_getpid)
+		: "x8", "x0"
+	);
+}
+
+/* stub_end marks the end of the .stub section for size calculation */
+void __attribute__ ((section (".stub"))) stub_end(void)
+{
+}

diff --git a/arch/arm64/um/task_size.c b/arch/arm64/um/task_size.c
new file mode 100644
--- /dev/null
+++ b/arch/arm64/um/task_size.c
@@ -0,0 +1,20 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * arch/arm64/um/task_size.c
+ *
+ * TASK_SIZE for UML on arm64.
+ * We limit guest virtual address space to 512 GB (39-bit VA, matching
+ * the default arm64 kernel with 4K pages and 3-level page tables).
+ * This keeps the UML host and guest address spaces well-separated.
+ */
+
+#include <linux/types.h>
+#include <asm/page.h>
+
+/* 512 GB — same as arm64 kernel default with PAGE_SHIFT=12, VA_BITS=39 */
+#define UML_TASK_SIZE  (1UL << 39)
+
+unsigned long task_size(void)
+{
+	return UML_TASK_SIZE;
+}

diff --git a/arch/arm64/um/os-Linux/registers.c b/arch/arm64/um/os-Linux/registers.c
new file mode 100644
--- /dev/null
+++ b/arch/arm64/um/os-Linux/registers.c
@@ -0,0 +1,72 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * arch/arm64/um/os-Linux/registers.c
+ *
+ * Host-side (os-Linux) register access for UML on arm64.
+ * Runs in the UML kernel thread context; uses ptrace to read/write
+ * guest register state.
+ *
+ * arm64 does NOT have PTRACE_GETREGS/PTRACE_SETREGS.
+ * We must use PTRACE_GETREGSET/SETREGSET with NT_PRSTATUS.
+ */
+
+#include <sys/ptrace.h>
+#include <sys/uio.h>
+#include <elf.h>
+#include <errno.h>
+#include <string.h>
+#include "os.h"
+#include "registers.h"
+#include "skas/skas.h"
+
+/* arm64 user_pt_regs: 31 GPR + sp + pc + pstate = 34 × 8 = 272 bytes */
+struct host_regs {
+	unsigned long long regs[31];
+	unsigned long long sp;
+	unsigned long long pc;
+	unsigned long long pstate;
+};
+
+int save_registers(int pid, struct uml_pt_regs *regs)
+{
+	struct iovec iov = {
+		.iov_base = &regs->gp,
+		.iov_len  = sizeof(struct host_regs),
+	};
+	int ret;
+
+	ret = ptrace(PTRACE_GETREGSET, pid, (void *)NT_PRSTATUS, &iov);
+	if (ret < 0)
+		return -errno;
+	return 0;
+}
+
+int restore_registers(int pid, struct uml_pt_regs *regs)
+{
+	struct iovec iov = {
+		.iov_base = &regs->gp,
+		.iov_len  = sizeof(struct host_regs),
+	};
+	int ret;
+
+	ret = ptrace(PTRACE_SETREGSET, pid, (void *)NT_PRSTATUS, &iov);
+	if (ret < 0)
+		return -errno;
+	return 0;
+}
+
+int get_fp_registers(int pid, unsigned long *regs)
+{
+	/* arm64 FP/SIMD state via NT_ARM_VFP — optional for minimal port */
+	return 0;
+}
+
+int put_fp_registers(int pid, unsigned long *regs)
+{
+	return 0;
+}
+
+void arch_init_registers(int pid)
+{
+	/* Nothing to initialize on arm64 for the ptrace register interface */
+}

diff --git a/arch/arm64/um/os-Linux/signal.c b/arch/arm64/um/os-Linux/signal.c
new file mode 100644
--- /dev/null
+++ b/arch/arm64/um/os-Linux/signal.c
@@ -0,0 +1,48 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * arch/arm64/um/os-Linux/signal.c
+ *
+ * Host-side signal setup for UML on arm64.
+ * Installs the SIGSEGV/SIGTRAP handlers used by the skas execution engine.
+ */
+
+#include <signal.h>
+#include <string.h>
+#include <errno.h>
+#include "os.h"
+#include "skas/skas.h"
+
+/*
+ * UML requires SA_NODEFER on its SIGSEGV handler so that nested SIGSEGVs
+ * (e.g. during stack overflow handling) don't get blocked.
+ */
+void set_sigstack(void *sig_stack, int size)
+{
+	stack_t ss = {
+		.ss_sp    = sig_stack,
+		.ss_flags = 0,
+		.ss_size  = size,
+	};
+
+	if (sigaltstack(&ss, NULL) < 0)
+		panic("sigaltstack failed: %s", strerror(errno));
+}
+
+void remove_sigstack(void)
+{
+	stack_t ss = { .ss_flags = SS_DISABLE };
+	sigaltstack(&ss, NULL);
+}
+
+void (*arch_get_signal_handler(int sig))(int, struct siginfo *, void *)
+{
+	return NULL;
+}
+
+/* arm64 has no restorer quirks — the vDSO provides rt_sigreturn */
+void arch_do_signal(struct pt_regs *regs, int sig)
+{
+}

diff --git a/arch/arm64/um/os-Linux/prctl.c b/arch/arm64/um/os-Linux/prctl.c
new file mode 100644
--- /dev/null
+++ b/arch/arm64/um/os-Linux/prctl.c
@@ -0,0 +1,18 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * arch/arm64/um/os-Linux/prctl.c
+ * No arm64-specific prctl hooks needed for the minimal UML port.
+ */
+
+#include <sys/prctl.h>
+#include "os.h"
+
+void arch_prctl_defaults(void)
+{
+	/*
+	 * Disable pointer authentication (PAC) for UML processes so that
+	 * ptrace register reads/writes are not corrupted by PAC keys.
+	 * Available on Linux 5.13+ via PR_PAC_RESET_KEYS.
+	 */
+	prctl(PR_PAC_RESET_KEYS, PR_PAC_APIAKEY | PR_PAC_APIBKEY |
+	      PR_PAC_APDAKEY | PR_PAC_APDBKEY | PR_PAC_APGAKEY, 0, 0, 0);
+}

