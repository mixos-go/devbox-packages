From: DevBox UML arm64 Port
Subject: [PATCH 3c/7] arm64/um: add task_size.c

diff --git a/arch/arm64/um/task_size.c b/arch/arm64/um/task_size.c
new file mode 100644
--- /dev/null
+++ b/arch/arm64/um/task_size.c
@@ -0,0 +1,17 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * arch/arm64/um/task_size.c
+ *
+ * TASK_SIZE for UML on arm64.
+ * 512 GB (39-bit VA) - matches arm64 default with 4K pages, 3-level page tables.
+ */
+
+#include <linux/types.h>
+#include <asm/page.h>
+
+#define UML_TASK_SIZE  (1UL << 39)
+
+unsigned long task_size(void)
+{
+	return UML_TASK_SIZE;
+}
