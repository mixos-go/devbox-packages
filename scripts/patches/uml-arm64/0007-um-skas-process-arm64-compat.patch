+		if (sysemu_supported) {
+			op = singlestepping() ? PTRACE_SYSEMU_SINGLESTEP
+					      : PTRACE_SYSEMU;
+		} else {
+			op = PTRACE_SYSCALL;
+		}
 
 		if (ptrace(op, pid, 0, 0)) {
 			printk(UM_KERN_ERR "%s - ptrace continue failed, op = %d, errno = %d\n",
@@ -252,12 +322,26 @@ void userspace(struct uml_pt_regs *regs, unsigned long *aux_fp_regs)
 			fatal_sigsegv();
