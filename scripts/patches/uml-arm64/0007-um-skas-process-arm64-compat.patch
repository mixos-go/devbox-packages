+/*
+ * arm64 / PTRACE_SYSCALL fallback helpers.
+ *
+ * When sysemu_supported==0 we use PTRACE_SYSCALL (two stops per syscall):
+ *   - at_syscall_entry: true  = we are at the entry stop
+ *                       false = we are at the exit stop (or non-syscall stop)
+ *
+ * At entry stop we neutralise the syscall so the host executes something
+ * harmless (__NR_getpid), then continue to the exit stop.
+ * At exit stop we restore the original syscall number so handle_trap()
+ * can dispatch it inside UML, then write the return value back.
+ */
+static bool at_syscall_entry;
+static unsigned long saved_syscall_nr;
+
+static inline void arm64_neutralize_syscall(int pid, struct uml_pt_regs *regs)
+{
+	/* Replace real syscall nr with __NR_getpid — completely harmless */
+	UPT_SYSCALL_NR(regs) = __NR_getpid;
+	restore_registers(pid, regs); /* write modified regs to child */
+}
